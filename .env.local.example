# Neon Database Connection
# Format: postgresql://[user]:[password]@[endpoint]/[dbname]?sslmode=require
# Example: postgresql://myuser:mypassword@ep-cool-name-123456.us-east-2.aws.neon.tech/mydb?sslmode=require
DATABASE_URL=

# Google API Key (for Gemini embeddings)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic API Key (for Claude Sonnet generation)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
